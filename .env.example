# Server Configuration
PORT=3000
NODE_ENV=development

# Security
JWT_SECRET=your_super_secret_jwt_key_here
# BCRYPT_SALT_ROUNDS=10 (Default)

# Database
# Use your PostgreSQL connection string
DATABASE_URL=postgres://user:password@hostname:5432/databasename?sslmode=require

# CORS
# ALLOWED_ORIGINS=https://yourfrontend.vercel.app,http://localhost:5173
